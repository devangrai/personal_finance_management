{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "PLAID_CLIENT_ID",
    "PLAID_SECRET",
    "PLAID_SANDBOX_SECRET",
    "PLAID_DEVELOPMENT_SECRET",
    "PLAID_PRODUCTION_SECRET",
    "PLAID_ENV",
    "PLAID_CLIENT_NAME",
    "PLAID_COUNTRY_CODES",
    "PLAID_PRODUCTS",
    "PLAID_REDIRECT_URI",
    "NEXT_PUBLIC_APP_URL",
    "ENCRYPTION_KEY",
    "DEFAULT_USER_EMAIL",
    "CRON_SECRET",
    "OPENAI_API_KEY",
    "OPENAI_MODEL",
    "GEMINI_API_KEY",
    "GEMINI_MODEL"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**",
        "tsconfig.json",
        "package.json",
        "prisma/schema.prisma",
        "prisma/migrations/**",
        "app/**",
        "lib/**",
        "next.config.ts",
        "next.config.mjs"
      ],
      "outputs": [
        ".next/**",
        "dist/**",
        "../../node_modules/.prisma/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ],
      "outputs": []
    }
  }
}
